<Window x:Class="RPGCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание персонажа RPG" Height="650" Width="700"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Имя персонажа -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="👤 Имя персонажа:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="NameTextBox" Height="30" Padding="5" FontSize="14"/>
        </StackPanel>

        <!-- Выбор класса -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="⚔️ Класс персонажа:" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <RadioButton x:Name="WarriorRadio" Content="🗡️ Воин" GroupName="Class" Margin="0,5,0,0" IsChecked="True"/>
            <RadioButton x:Name="MageRadio" Content="🔮 Маг" GroupName="Class" Margin="0,5,0,0"/>
            <RadioButton x:Name="ArcherRadio" Content="🏹 Лучник" GroupName="Class" Margin="0,5,0,0"/>
            <RadioButton x:Name="RogueRadio" Content="🗡️ Вор" GroupName="Class" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Выбор навыков с отображением стоимости -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="📚 Навыки (выберите несколько):" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
            <TextBlock Text="💰 Доступно очков: 10" FontSize="12" Foreground="Green" Margin="0,0,0,5"/>
            <CheckBox x:Name="SmithingCheck" Content="⚒️ Кузнечное дело (3 очка)" Margin="0,5,0,0"/>
            <CheckBox x:Name="AlchemyCheck" Content="🧪 Алхимия (4 очка)" Margin="0,5,0,0"/>
            <CheckBox x:Name="PotionCheck" Content="🍃 Зельеварение (4 очка)" Margin="0,5,0,0"/>
            <CheckBox x:Name="LockpickCheck" Content="🔓 Взлом замков (2 очка)" Margin="0,5,0,0"/>
            <CheckBox x:Name="StealthCheck" Content="👻 Скрытность (3 очка)" Margin="0,5,0,0"/>
            <TextBlock x:Name="PointsLeftText" Text="Осталось очков: 10" FontSize="12" Foreground="Blue" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
            <Button x:Name="CreateButton" Content="✅ Создать персонажа" Width="150" Height="35" Margin="5" Click="CreateButton_Click"/>
            <Button x:Name="ResetButton" Content="🔄 Сбросить" Width="100" Height="35" Margin="5" Click="ResetButton_Click"/>
            <Button x:Name="RandomButton" Content="🎲 Случайный выбор" Width="150" Height="35" Margin="5" Click="RandomButton_Click"/>
        </StackPanel>

        <!-- Результат -->
        <GroupBox Grid.Row="4" Header="📜 Информация о персонаже" Margin="0,5,0,0">
            <ScrollViewer>
                <TextBox x:Name="ResultTextBox" TextWrapping="Wrap" Padding="10" FontSize="12" 
                         IsReadOnly="True" Background="#FFF9F9F9"/>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>